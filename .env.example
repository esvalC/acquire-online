# Copy this to .env and fill in real values before deploying.
# Never commit .env to git.

# ── JWT ──────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-random-64-char-string

# ── Phone hash salt ───────────────────────────────────────────────
# Same instructions — separate random value from JWT_SECRET
PHONE_HASH_SALT=change-me-to-another-random-string

# ── Phone encryption key ───────────────────────────────────────────
# 32 bytes = 64 hex chars. Used for AES-256-GCM encryption of phone
# numbers (needed to send OTP on username-based login).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHONE_ENCRYPT_KEY=change-me-to-a-64-char-hex-string

# ── Twilio ────────────────────────────────────────────────────────
# Leave blank to run in dev mode (OTP printed to server console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=

# ── Database ──────────────────────────────────────────────────────
# Defaults to ./data/acquire.db if not set
# DB_PATH=/var/data/acquire.db

# ── Admin ─────────────────────────────────────────────────────────
# Set once, promote your account, then delete this line.
# curl -X POST /api/admin/promote -H "X-Admin-Secret: <secret>" -d '{"username":"you"}'
ADMIN_PROMOTE_SECRET=

# ── Server ────────────────────────────────────────────────────────
PORT=3000
